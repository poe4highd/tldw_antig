# Supabase Configuration (Frontend)
# Found in Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://cmgsjezztyvcikyweeuz.supabase.co
# Supabase recommends using Publishable API keys for client-side use
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Site Configuration
# For local dev: http://localhost:3000
# For production: https://read-tube.com
NEXT_PUBLIC_SITE_URL=https://read-tube.com

# Dev Page Password
NEXT_PUBLIC_DEV_PASSWORD=your_dev_password_here

# === Analytics & SEO ===
# Google Search Console verification code (from GSC HTML tag method)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Microsoft Clarity Project ID
NEXT_PUBLIC_CLARITY_ID=your-clarity-project-id
